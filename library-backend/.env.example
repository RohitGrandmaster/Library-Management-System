# ============================================================
#  NestJS Backend — Environment Variables Template
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git!
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL Database ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=library360

# ── JWT Secrets (generate with: openssl rand -hex 64) ────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ── WhatsApp / Messaging (optional) ─────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ── Email (optional) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
