# ============================================================
#  Library Management System — Monorepo .gitignore
#  Covers: NestJS Backend + Next.js Frontend
# ============================================================

# ── Node / npm ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn-integrity

# ── NestJS Backend Build ─────────────────────────────────────
library-backend/dist/
library-backend/build/
library-backend/.cache/

# ── Next.js Frontend Build ───────────────────────────────────
libraryManagementFrontendNextJs/my-app/.next/
libraryManagementFrontendNextJs/my-app/out/
libraryManagementFrontendNextJs/my-app/build/

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# ── Environment Files (NEVER commit secrets!) ────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.production
.env.production.local
*.env.backup
!.env.example
!.env.template

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.log.*
pino.log

# ── Testing & Coverage ───────────────────────────────────────
coverage/
.nyc_output/
jest-results/
test-results/
playwright-report/
.pytest_cache/
__pycache__/
*.pyc

# ── Docker local overrides ───────────────────────────────────
docker-compose.override.yml
docker-compose.local.yml
.docker/
pgdata/
redisdata/
miniodata/

# ── Database ─────────────────────────────────────────────────
*.sql.bak
*.dump
*.sqlite
*.db

# ── OS Generated ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs and Editors ─────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.classpath
.settings/

# ── Vercel / Netlify / CI ────────────────────────────────────
.vercel
.netlify

# ── Security / Certs ─────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/

# ── Temporary / Misc ─────────────────────────────────────────
temp.html
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
.qodo/
.agents/

# ── Storybook ────────────────────────────────────────────────
storybook-static/
