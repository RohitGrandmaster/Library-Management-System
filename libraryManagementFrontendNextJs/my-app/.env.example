# ============================================================
#  Next.js Frontend — Environment Variables Template
#  Copy this file to .env.local and fill in your values
#  NEVER commit .env.local to git!
# ============================================================

# ── Backend API URL ──────────────────────────────────────────
# Development: local backend server
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api/v1

# Production (Docker/Nginx): internal service name
# NEXT_PUBLIC_API_URL=http://backend:3001/api/v1

# Production (public domain):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Smart Library 360
NEXT_PUBLIC_APP_VERSION=1.0.0
